<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CFTimer.ViewModels"
             x:Class="CFTimer.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- General Section -->
            <Label Text="General" FontSize="13" FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,0"/>
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Padding="16" Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="48">
                        <Label Text="Sound" VerticalOptions="Center" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                        <Switch Grid.Column="1" IsToggled="{Binding SoundEnabled}" VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="48">
                        <Label Text="Vibration" VerticalOptions="Center" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                        <Switch Grid.Column="1" IsToggled="{Binding VibrationEnabled}" VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="48">
                        <Label Text="Countdown Before Start" VerticalOptions="Center" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                        <Switch Grid.Column="1" IsToggled="{Binding CountdownEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Display Section -->
            <Label Text="Display" FontSize="13" FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,0"/>
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Padding="16" Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="48">
                        <Label Text="Keep Screen Awake" VerticalOptions="Center" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                        <Switch Grid.Column="1" IsToggled="{Binding KeepScreenAwake}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Timer Defaults -->
            <Label Text="Timer Defaults" FontSize="13" FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,0"/>
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Default Prep Time (seconds)" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Button Text="-" WidthRequest="44" HeightRequest="44" CornerRadius="22"
                                BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource TextPrimary}"
                                Clicked="OnDecrementPrep"/>
                        <Label Text="{Binding DefaultPrepSeconds}" FontSize="28" FontFamily="OpenSansSemibold"
                               VerticalOptions="Center" WidthRequest="50" HorizontalTextAlignment="Center"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Button Text="+" WidthRequest="44" HeightRequest="44" CornerRadius="22"
                                BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource TextPrimary}"
                                Clicked="OnIncrementPrep"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- About Section -->
            <Label Text="About" FontSize="13" FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,0"/>
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Padding="16" Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="48">
                        <Label Text="Version" VerticalOptions="Center" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                        <Label Grid.Column="1" Text="{Binding AppVersion}" VerticalOptions="Center" FontSize="16"
                               TextColor="{StaticResource TextSecondary}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="40" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
