<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CFTimer.ViewModels"
             xmlns:models="clr-namespace:CFTimer.Models"
             x:Class="CFTimer.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- Clear button -->
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="End" Padding="16,8">
            <Button Text="Clear All" Command="{Binding ClearHistoryCommand}"
                    BackgroundColor="Transparent" TextColor="{StaticResource DangerColor}"
                    FontSize="14" Padding="8,0"
                    IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}"/>
        </HorizontalStackLayout>

        <!-- History List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Entries}" Margin="16,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="20">
                    <Label Text="No workouts yet" FontSize="20" FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center" TextColor="{StaticResource TextSecondary}"/>
                    <Label Text="Complete your first workout to see it here"
                           FontSize="14" HorizontalOptions="Center" TextColor="{StaticResource TextSecondary}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:HistoryEntry">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete" BackgroundColor="{StaticResource DangerColor}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=DeleteEntryCommand}"
                                           CommandParameter="{Binding}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                            <Grid Padding="16" ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding WorkoutName}" FontFamily="OpenSansSemibold" FontSize="16"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding TimerType}" FontSize="12" TextColor="{StaticResource Primary}"/>
                                        <Label Text="{Binding CompletedAt, StringFormat='{0:MMM dd, yyyy HH:mm}'}"
                                               FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding DurationFormatted}" FontSize="16"
                                       FontFamily="OpenSansSemibold" VerticalOptions="Center"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
