<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CFTimer.ViewModels"
             x:Class="CFTimer.Views.TimerSetupPage"
             x:DataType="vm:TimerSetupViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Workout Name -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Workout Name" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                    <Entry Text="{Binding WorkoutName}" Placeholder="e.g. Morning WOD" FontSize="16"/>
                </VerticalStackLayout>
            </Border>

            <!-- Rounds -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowRounds}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Rounds" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Button Text="-" WidthRequest="48" HeightRequest="48" CornerRadius="24"
                                BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource TextPrimary}"
                                Clicked="OnDecrementRounds"/>
                        <Label Text="{Binding TotalRounds}" FontSize="32" FontFamily="OpenSansSemibold"
                               VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="60"
                               HorizontalTextAlignment="Center" TextColor="{StaticResource TextPrimary}"/>
                        <Button Text="+" WidthRequest="48" HeightRequest="48" CornerRadius="24"
                                BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource TextPrimary}"
                                Clicked="OnIncrementRounds"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Work / Rest Duration -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowWorkRest}">
                <VerticalStackLayout Padding="16" Spacing="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Work Duration" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Entry Text="{Binding WorkMinutes}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                            <Label Text=":" FontSize="24" VerticalOptions="Center"/>
                            <Entry Text="{Binding WorkSeconds}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Rest Duration" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Entry Text="{Binding RestMinutes}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                            <Label Text=":" FontSize="24" VerticalOptions="Center"/>
                            <Entry Text="{Binding RestSeconds}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- EMOM Interval -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowInterval}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Interval Duration" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Entry Text="{Binding IntervalMinutes}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                        <Label Text=":" FontSize="24" VerticalOptions="Center"/>
                        <Entry Text="{Binding IntervalSeconds}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Total Duration (Countdown / AMRAP) -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowTotalDuration}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Total Duration" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Entry Text="{Binding TotalMinutes}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                        <Label Text=":" FontSize="24" VerticalOptions="Center"/>
                        <Entry Text="{Binding TotalSeconds}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Time Cap (ForTime) -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowTimeCap}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Time Cap (optional)" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Entry Text="{Binding TimeCapMinutes}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                        <Label Text=":" FontSize="24" VerticalOptions="Center"/>
                        <Entry Text="{Binding TimeCapSeconds}" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" FontSize="24"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Prep Time -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowPrep}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Prep Countdown (seconds)" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Button Text="-" WidthRequest="48" HeightRequest="48" CornerRadius="24"
                                BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource TextPrimary}"
                                Clicked="OnDecrementPrep"/>
                        <Label Text="{Binding PrepSeconds}" FontSize="32" FontFamily="OpenSansSemibold"
                               VerticalOptions="Center" WidthRequest="60"
                               HorizontalTextAlignment="Center" TextColor="{StaticResource TextPrimary}"/>
                        <Button Text="+" WidthRequest="48" HeightRequest="48" CornerRadius="24"
                                BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource TextPrimary}"
                                Clicked="OnIncrementPrep"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Notes -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label Text="Notes" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                    <Editor Text="{Binding Notes}" Placeholder="Workout notes..." HeightRequest="80" FontSize="14"/>
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <Button Text="Start Workout" Command="{Binding StartWorkoutCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    FontFamily="OpenSansSemibold" FontSize="18" HeightRequest="56" CornerRadius="16"/>

            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button Text="Save" Command="{Binding SaveWorkoutCommand}"
                        BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource TextPrimary}"
                        FontSize="14" HeightRequest="44" CornerRadius="12" Padding="24,0"/>
                <Button Text="Save &amp; Start" Command="{Binding SaveAndStartCommand}"
                        BackgroundColor="{StaticResource Secondary}" TextColor="White"
                        FontSize="14" HeightRequest="44" CornerRadius="12" Padding="24,0"/>
            </HorizontalStackLayout>

            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
