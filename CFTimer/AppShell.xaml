<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CFTimer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CFTimer.Views"
    Title="CFTimer">

    <TabBar>
        <ShellContent Title="Home" Route="home"
                      ContentTemplate="{DataTemplate views:HomePage}"
                      Icon="{OnPlatform Default='home_icon.png'}"/>

        <ShellContent Title="Workouts" Route="workouts"
                      ContentTemplate="{DataTemplate views:WorkoutsPage}"
                      Icon="{OnPlatform Default='workouts_icon.png'}"/>

        <ShellContent Title="History" Route="history"
                      ContentTemplate="{DataTemplate views:HistoryPage}"
                      Icon="{OnPlatform Default='history_icon.png'}"/>

        <ShellContent Title="Settings" Route="settings"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Icon="{OnPlatform Default='settings_icon.png'}"/>
    </TabBar>

</Shell>
